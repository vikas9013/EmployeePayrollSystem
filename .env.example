# Environment Variables for Render Deployment
# Copy these to Render's environment variables section in dashboard
# NEVER commit this file with real values - it's for reference only!

# ============================================================
# PostgreSQL Database (from Render PostgreSQL Service)
# ============================================================
# Get these values from your Render PostgreSQL service dashboard
DB_URL=postgresql://payroll_user:PASSWORD@hostname:5432/payrolldb
DB_USERNAME=payroll_user
DB_PASSWORD=your-postgres-password-here

# ============================================================
# Redis Cache (from Render Redis Service)
# ============================================================
# Get these values from your Render Redis service dashboard
REDIS_HOST=redis-xxxx.render.com
REDIS_PORT=6379

# ============================================================
# JWT Authentication
# ============================================================
# Generate a random 32+ character string for production
# Use: openssl rand -base64 32
JWT_SECRET=ThisIsASecretKeyThatMustBe32CharsLong!!ChangeMe123!

# ============================================================
# Groq API Key (for AI Onboarding)
# ============================================================
# Get free API key from https://console.groq.com
GROQ_API_KEY=gsk_your_actual_groq_api_key_here

# ============================================================
# Optional: Server Configuration
# ============================================================
# Usually not needed - Render handles most of this
# server.port=8080  # Render uses port 8080 by default
# spring.profiles.active=production

